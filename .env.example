# Spotify Developer App — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:4000/auth/callback

# JWT — string larga y aleatoria
JWT_SECRET=a_long_random_secret_string

# Base de datos PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Clave de cifrado AES-256-GCM — exactamente 64 caracteres hex
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=64_hex_characters_here

# URL del frontend
FRONTEND_URL=http://localhost:5173

# Puerto del servidor
PORT=4000

# Daily challenge
DAILY_PLAYLIST_URL=https://open.spotify.com/playlist/your_playlist_id
DAILY_TRACK_COUNT=5

# Secret para el endpoint del cron job
CRON_SECRET=a_random_secret_for_the_cron_endpoint